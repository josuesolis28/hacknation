{
  "buildCommand": "cd frontend && rm -f package-lock.json && npm install --include=dev && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hacknation-production-c4c8.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
