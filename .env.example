# ============================================================
# The VC Brain — Variables de entorno
# Copia este archivo como `.env` y rellena tus credenciales.
# NUNCA subas el archivo .env a git.
# ============================================================

# --- Credenciales de APIs (mandatorias) ---
OPENAI_API_KEY=sk-proj-...

# --- Configuración del motor cognitivo ---
LLM_PROVIDER=openai

# Modelo usado para extraer/evaluar startups (opcional — este es el default)
OPENAI_MODEL=gpt-4o

# Modelo usado por el Scout para buscar en la web (tool "web_search")
OPENAI_SEARCH_MODEL=gpt-4o

# Modelo barato usado solo para traducir (ES/EN/DE) — no necesita razonamiento
OPENAI_TRANSLATE_MODEL=gpt-5.4-mini

# --- Parámetros de búsqueda (opcional) ---
# Número máximo de fuentes que se piden por consulta de búsqueda
SEARCH_MAX_RESULTS=4
# Queries de búsqueda en paralelo (más alto = más rápido, más caro de golpe)
SEARCH_CONCURRENCY=8
# Tope de costo estimado (USD) por corrida completa de Scout + Judge
MAX_SEARCH_COST_USD=2.0

# --- Acceso B2B local ---
# Cambia estos valores antes de desplegar. En desarrollo: admin12345 / admin12345
VCBRAIN_ADMIN_USERNAME=admin12345
VCBRAIN_ADMIN_PASSWORD=admin12345
# Cuenta fija de prueba para el lado startup (demo/QA). Cambiar antes de producción.
VCBRAIN_STARTUP_USERNAME=startup1
VCBRAIN_STARTUP_PASSWORD=startup1
# Genera un secreto largo y aleatorio para producción.
VCBRAIN_JWT_SECRET=replace-with-a-long-random-secret
# TTL del token (segundos). Default 28800 = 8h para demos MVP.
VCBRAIN_JWT_TTL_SECONDS=28800

# --- Login con Google (opcional) ---
# 1. Ve a https://console.cloud.google.com/apis/credentials
# 2. Crea credenciales → "OAuth client ID" → tipo "Web application"
# 3. En "Authorized JavaScript origins" agrega tu URL del frontend
#    (dev: http://localhost:5173 — y el puerto que uses en prod)
# 4. Copia el Client ID (NO el secret, no se usa en este flujo) aquí abajo.
# Si se deja vacío, el botón de Google simplemente no aparece en el login.
GOOGLE_CLIENT_ID=

# --- Idioma del workspace (en | es | de) ---
VCBRAIN_DEFAULT_LANGUAGE=en

# --- Base de datos ---
# Vacío = usa un archivo SQLite local (vcbrain.db, gitignored). Para producción
# en Railway, agrega el plugin de Postgres al proyecto: Railway inyecta esta
# variable automáticamente, no hace falta escribirla a mano ahí.
# Formato local: postgresql://usuario:password@localhost:5432/vcbrain
DATABASE_URL=

# --- CORS ---
# Orígenes permitidos, separados por coma. Agrega tu URL de Vercel en producción.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Licencia ---
# El backend NO arranca sin el valor correcto (ver vcbrain/license_gate.py).
# Este proyecto es propietario — solo el autor tiene el valor real.
LICENSE_KEY=
